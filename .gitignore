# VerseFlow .gitignore
# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/

# VerseFlow specific
.backups/
*.verseplaylist.bak*
*.verseplaylist.bak1
*.verseplaylist.bak2
*.verseplaylist.bak3

# Database (local development only - don't commit dev DB)
*.db

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# Virtual environments
.venv/
venv/
env/

# Test playlists at root (exclude, but preserve Archive)
*.verseplaylist
!Archive/*.verseplaylist

# AI conversation logs
GEMINI.MD
QWEN.md
Helper.txt
Help qwen.txt
