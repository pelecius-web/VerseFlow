{
  "name": "High Contrast",
  "id": "high_contrast",
  "description": "High contrast theme for accessibility and projector visibility",
  "version": "1.0",
  "schema_version": "2.0",
  "colors": {
    "bg_primary": "#000000",
    "bg_secondary": "#0a0a0a",
    "bg_sidebar": "#111111",
    "bg_sidebar_end": "#0a0a0a",
    "bg_panel_start": "rgba(20,20,20,0.95)",
    "bg_panel_end": "rgba(10,10,10,0.95)",
    "bg_input": "rgba(30,30,30,0.95)",
    "bg_preview_center": "#1a1a1a",
    "bg_preview_edge": "#000000",
    "bg_statusbar": "rgba(10,10,10,0.95)",
    "gold": "#ffd700",
    "gold_dim": "rgba(255,215,0,0.15)",
    "gold_border": "rgba(255,215,0,0.5)",
    "gold_text": "#ffd700",
    "text_primary": "#ffffff",
    "text_dim": "rgba(255,255,255,0.6)",
    "text_faint": "rgba(255,255,255,0.3)",
    "text_verse": "#e0e0e0",
    "text_verse_active": "#ffffff",
    "green": "#00ff88",
    "green_dim": "rgba(0,255,136,0.15)",
    "red": "#ff4444",
    "red_dim": "rgba(255,68,68,0.15)",
    "red_text": "rgba(255,68,68,0.7)",
    "scrollbar": "rgba(255,215,0,0.3)",
    "scrollbar_hover": "rgba(255,215,0,0.5)",
    "card_highlight_bg": "rgba(255,215,0,0.15)",
    "card_highlight_border": "#ffd700",
    "card_hover_bg": "rgba(255,215,0,0.08)",
    "card_hover_border": "rgba(255,215,0,0.3)",
    "panel_border": "rgba(255,255,255,0.15)",
    "panel_border_hover": "rgba(255,215,0,0.3)",
    "input_border": "rgba(255,255,255,0.2)",
    "input_focus_border": "rgba(255,215,0,0.6)",
    "statusbar_border": "rgba(255,255,255,0.08)",
    "badge_bg": "rgba(255,215,0,0.12)",
    "badge_border": "rgba(255,215,0,0.3)",
    "badge_text": "rgba(255,215,0,0.8)",
    "nav_active_bg": "rgba(255,215,0,0.1)",
    "nav_active_text": "#ffffff",
    "nav_inactive_text": "rgba(255,215,0,0.4)",
    "crossref_bg": "rgba(255,215,0,0.08)",
    "crossref_border": "rgba(255,215,0,0.2)",
    "crossref_text": "rgba(255,215,0,0.7)",
    "draft_bg": "rgba(0,255,136,0.08)",
    "draft_border": "rgba(0,255,136,0.3)",
    "draft_text": "rgba(0,255,136,0.8)"
  },
  "fonts": {
    "family": "Segoe UI",
    "logo_size": 20,
    "logo_weight": "Bold",
    "header_size": 24,
    "header_weight": "Light",
    "panel_header_size": 10,
    "panel_header_weight": "Bold",
    "verse_size": 12,
    "verse_text_size": 12,
    "input_size": 13,
    "badge_size": 9,
    "ref_size": 14,
    "ref_weight": "Bold",
    "nav_size": 13,
    "nav_weight": "Normal",
    "nav_active_weight": "Bold"
  },
  "animation": {
    "transition_duration_ms": 200,
    "pulse_duration_ms": 1200,
    "highlight_transition_ms": 100
  },
  "spacing": {
    "sidebar_width": 220,
    "panel_margin": 32,
    "panel_spacing": 12,
    "card_height": 90,
    "border_radius": 8,
    "input_border_radius": 6,
    "card_border_radius": 6
  },
  "typography": {
    "compact":   { "size": 9,  "weight": "Bold",   "uppercase": true,  "letter_spacing": 2 },
    "standard":  { "size": 13, "weight": "Bold",   "uppercase": false, "letter_spacing": 0 },
    "body":      { "size": 10, "weight": "Normal", "uppercase": false, "letter_spacing": 0 },
    "hint":      { "size": 9,  "weight": "Normal", "uppercase": false, "letter_spacing": 0 }
  },
  "fullscreen": {
    "background_color": "#0a0a0a",
    "background_image": null,
    "background_image_fit": "cover",
    "background_image_opacity": 1.0,
    "ref_color": "#ffd700",
    "verse_color": "#ffffff",
    "ref_font_family": "Segoe UI",
    "ref_font_weight": "Black",
    "verse_font_family": "Segoe UI",
    "verse_font_weight": "Normal"
  },
  "lower_third": {
    "logo_path": null,
    "logo_format": "auto",
    "show_logo_placeholder": true,
    "logo_width_ratio": 0.16,
    "logo_max_height_ratio": 0.70,
    "show_separator": true,
    "separator_width": 1,
    "separator_color": "#ffffff",
    "background_image": null,
    "background_image_fit": "cover",
    "height_ratio": 0.30,
    "background_color": "#000000",
    "background_alpha": 0.85,
    "accent_color": "#ffffff",
    "ref_color": "#ffd700",
    "verse_color": "#ffffff",
    "ref_font_family": "Segoe UI",
    "verse_font_family": "Segoe UI",
    "church_name_color": "#ffd700",
    "transition": {
      "type": "none",
      "duration_ms": 200,
      "easing": "OutCubic"
    }
  },
  "thumbnail_style": {
    "background_mode": "flat",
    "surface": "none",
    "accent_layout": "top_rule",
    "contrast_boost": 1.0,
    "text_treatment": "live_centered"
  }
}
