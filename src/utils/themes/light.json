{
  "name": "Light",
  "id": "light",
  "description": "Clean light theme for bright environments",
  "version": "1.0",
  "schema_version": "2.0",
  "colors": {
    "bg_primary": "#f5f3ef",
    "bg_secondary": "#ede9e3",
    "bg_sidebar": "#2c2c3a",
    "bg_sidebar_end": "#1e1e2a",
    "bg_panel_start": "rgba(255,255,255,0.95)",
    "bg_panel_end": "rgba(245,243,239,0.95)",
    "bg_input": "rgba(255,255,255,0.9)",
    "bg_preview_center": "#ffffff",
    "bg_preview_edge": "#f0ece6",
    "bg_statusbar": "rgba(240,236,230,0.95)",
    "gold": "#b8922e",
    "gold_dim": "rgba(184,146,46,0.12)",
    "gold_border": "rgba(184,146,46,0.35)",
    "gold_text": "#b8922e",
    "text_primary": "#2c2c2c",
    "text_dim": "rgba(44,44,44,0.5)",
    "text_faint": "rgba(44,44,44,0.2)",
    "text_verse": "#3a3a3a",
    "text_verse_active": "#1a1a1a",
    "green": "#3a8a5e",
    "green_dim": "rgba(58,138,94,0.12)",
    "red": "#c94435",
    "red_dim": "rgba(201,68,53,0.12)",
    "red_text": "rgba(201,68,53,0.7)",
    "scrollbar": "rgba(184,146,46,0.25)",
    "scrollbar_hover": "rgba(184,146,46,0.45)",
    "card_highlight_bg": "rgba(184,146,46,0.12)",
    "card_highlight_border": "#b8922e",
    "card_hover_bg": "rgba(184,146,46,0.06)",
    "card_hover_border": "rgba(184,146,46,0.2)",
    "panel_border": "rgba(0,0,0,0.08)",
    "panel_border_hover": "rgba(184,146,46,0.25)",
    "input_border": "rgba(0,0,0,0.12)",
    "input_focus_border": "rgba(184,146,46,0.4)",
    "statusbar_border": "rgba(0,0,0,0.06)",
    "badge_bg": "rgba(184,146,46,0.1)",
    "badge_border": "rgba(184,146,46,0.2)",
    "badge_text": "rgba(184,146,46,0.75)",
    "nav_active_bg": "rgba(184,146,46,0.1)",
    "nav_active_text": "#f5f3ef",
    "nav_inactive_text": "rgba(200,180,140,0.5)",
    "crossref_bg": "rgba(184,146,46,0.06)",
    "crossref_border": "rgba(184,146,46,0.15)",
    "crossref_text": "rgba(184,146,46,0.65)",
    "draft_bg": "rgba(58,138,94,0.08)",
    "draft_border": "rgba(58,138,94,0.25)",
    "draft_text": "rgba(58,138,94,0.75)"
  },
  "fonts": {
    "family": "Segoe UI",
    "logo_size": 20,
    "logo_weight": "Bold",
    "header_size": 24,
    "header_weight": "Light",
    "panel_header_size": 10,
    "panel_header_weight": "Bold",
    "verse_size": 12,
    "verse_text_size": 12,
    "input_size": 13,
    "badge_size": 9,
    "ref_size": 14,
    "ref_weight": "Bold",
    "nav_size": 13,
    "nav_weight": "Normal",
    "nav_active_weight": "Bold"
  },
  "animation": {
    "transition_duration_ms": 300,
    "pulse_duration_ms": 1500,
    "highlight_transition_ms": 150
  },
  "spacing": {
    "sidebar_width": 220,
    "panel_margin": 32,
    "panel_spacing": 12,
    "card_height": 90,
    "border_radius": 12,
    "input_border_radius": 8,
    "card_border_radius": 8
  },
  "typography": {
    "compact":   { "size": 9,  "weight": "Bold",   "uppercase": true,  "letter_spacing": 2 },
    "standard":  { "size": 13, "weight": "Bold",   "uppercase": false, "letter_spacing": 0 },
    "body":      { "size": 10, "weight": "Normal", "uppercase": false, "letter_spacing": 0 },
    "hint":      { "size": 9,  "weight": "Normal", "uppercase": false, "letter_spacing": 0 }
  },
  "fullscreen": {
    "background_color": "#ede9e3",
    "background_image": null,
    "background_image_fit": "cover",
    "background_image_opacity": 1.0,
    "ref_color": "#b8922e",
    "verse_color": "#2c2c2c",
    "ref_font_family": "Segoe UI",
    "ref_font_weight": "Black",
    "verse_font_family": "Segoe UI",
    "verse_font_weight": "Normal"
  },
  "lower_third": {
    "logo_path": null,
    "logo_format": "auto",
    "show_logo_placeholder": true,
    "logo_width_ratio": 0.16,
    "logo_max_height_ratio": 0.70,
    "show_separator": true,
    "separator_width": 1,
    "separator_color": "#8b7355",
    "background_image": null,
    "background_image_fit": "cover",
    "height_ratio": 0.30,
    "background_color": "#ffffff",
    "background_alpha": 0.90,
    "accent_color": "#8b7355",
    "ref_color": "#b8922e",
    "verse_color": "#2c2c2c",
    "ref_font_family": "Segoe UI",
    "verse_font_family": "Segoe UI",
    "church_name_color": "#b8922e",
    "transition": {
      "type": "none",
      "duration_ms": 200,
      "easing": "OutCubic"
    }
  },
  "thumbnail_style": {
    "background_mode": "flat",
    "surface": "paper",
    "accent_layout": "top_rule",
    "contrast_boost": 1.0,
    "text_treatment": "live_centered"
  }
}
